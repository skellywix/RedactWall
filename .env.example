# RedactWall configuration — copy to .env and adjust (or export in your shell)

# The legacy REDACTWALL_* keys below remain supported for existing installs.
# New deployments may use the equivalent REDACTWALL_* aliases documented in
# README.md and docs/DEPLOYMENT.md.

# Web/admin server
PORT=4000
NODE_ENV=development

# Set HTTPS=true or COOKIE_SECURE=true when the dashboard is served over TLS.
HTTPS=false
COOKIE_SECURE=false

# SQLite store path. Keep this on local disk, not a cloud-synced folder.
REDACTWALL_DB_PATH=./data/redactwall.db

# Optional policy and customer detector-pack paths. Docker customer-silo
# deployments default these to /data so policy edits survive image replacement.
REDACTWALL_POLICY_PATH=
REDACTWALL_CUSTOM_DETECTORS_PATH=

# Security Admin console credentials (CHANGE THESE before any real use)
ADMIN_USER=admin
ADMIN_PASSWORD=ChangeMe!2026
# Optional in development, required by production preflight for Security Admin login.
# Use a base32 secret from an authenticator app enrollment flow.
ADMIN_TOTP_SECRET=

# Optional read-only console account for demos and examiner reviews.
# Set both values together, and keep AUDITOR_USER distinct from ADMIN_USER.
AUDITOR_USER=
AUDITOR_PASSWORD=

# Optional dedicated Platform Operator sign-in (fleet/runtime duties: updates,
# posture triage, delivery checks - no policy or decision power).
OPERATOR_USER=
OPERATOR_PASSWORD=

# Secret used to sign session cookies (set a long random value in production)
REDACTWALL_SECRET=

# Key for encrypting retained raw prompts at rest (AES-256-GCM). Set a long
# random value and keep it STABLE across restarts, or sealed data can't be read.
# If unset, REDACTWALL_SECRET is used; if neither is set, raw prompts are not stored.
REDACTWALL_DATA_KEY=

# During data-key rotation only: the OLD key, so sealed records keep opening
# while node scripts/rotate-data-key.js reseals them under the new key.
# Unset once rotation reports unreadable: 0.
REDACTWALL_DATA_KEY_PREVIOUS=

# Storage driver. Default sqlite (single-node, local disk). Set postgres with
# REDACTWALL_DATABASE_URL for the shared/scale-out control plane; schema
# migrations apply automatically on startup for both drivers.
REDACTWALL_DB_DRIVER=
REDACTWALL_DATABASE_URL=

# Optional cloud semantic classifier (Nightfall/Strac-style). Configuring a
# URL sends gate-path PROMPT TEXT to that endpoint - an explicit operator
# choice. Results max-combine with the on-device engine; outages and timeouts
# fall back to local detection, never weaker than on-device.
REDACTWALL_SEMANTIC_REMOTE_URL=
REDACTWALL_SEMANTIC_REMOTE_KEY=
REDACTWALL_SEMANTIC_REMOTE_TIMEOUT_MS=1500

# API key the network proxy / SDK presents to the /api/v1/gate endpoint.
# Use a long random value for pilots and production.
INGEST_API_KEY=dev-ingest-key

# Optional app-to-LLM gateway settings for private apps and internal agents.
# Use a long client token and keep provider keys on the gateway host only.
REDACTWALL_GATEWAY_TOKEN=
REDACTWALL_GATEWAY_HOST=127.0.0.1
REDACTWALL_GATEWAY_UPSTREAM=https://api.openai.com
REDACTWALL_GATEWAY_UPSTREAM_API_KEY=
REDACTWALL_GATEWAY_UPSTREAM_AUTH_HEADER=authorization
REDACTWALL_GATEWAY_UPSTREAM_AUTH_SCHEME=Bearer
REDACTWALL_GATEWAY_AWS_REGION=
REDACTWALL_GATEWAY_AWS_SERVICE=bedrock
REDACTWALL_GATEWAY_AWS_ACCESS_KEY_ID=
REDACTWALL_GATEWAY_AWS_SECRET_ACCESS_KEY=
REDACTWALL_GATEWAY_AWS_SESSION_TOKEN=
REDACTWALL_GATEWAY_RATE_LIMIT=60
REDACTWALL_GATEWAY_RATE_WINDOW_MS=60000
# Use sqlite to share counters across same-host gateway workers, or http to
# delegate hashed limiter keys to a shared Redis/KV-backed limiter service.
REDACTWALL_GATEWAY_RATE_LIMIT_STORE=memory
REDACTWALL_GATEWAY_RATE_LIMIT_DB=./data/gateway-rate-limits.db
REDACTWALL_GATEWAY_RATE_LIMIT_URL=
REDACTWALL_GATEWAY_RATE_LIMIT_TOKEN=
REDACTWALL_GATEWAY_RATE_LIMIT_TIMEOUT_MS=2000
REDACTWALL_GATEWAY_ALLOWED_MODELS=

# Optional central limiter service for multi-worker or multi-host AI gateway
# deployments. Gateways call this with hashed client-token keys only.
REDACTWALL_RATE_LIMITER_TOKEN=
REDACTWALL_RATE_LIMITER_STORE=sqlite
REDACTWALL_RATE_LIMITER_DB=./data/gateway-shared-rate-limiter.db
REDACTWALL_RATE_LIMITER_REDIS_URL=
REDACTWALL_RATE_LIMITER_REDIS_PREFIX=redactwall:gateway:rl:
REDACTWALL_RATE_LIMITER_REDIS_TIMEOUT_MS=2000

# Optional endpoint-local OCR for image files. When unset, the agent
# auto-discovers a local tesseract install; without one it falls back to the
# bundled WASM engine (offline, using vendored language data); with neither,
# images stay ocr_required. Point at a specific local command to override;
# args JSON can include "{file}".
ENDPOINT_AGENT_OCR_COMMAND=
ENDPOINT_AGENT_OCR_ARGS_JSON=
ENDPOINT_AGENT_OCR_TIMEOUT_MS=15000
ENDPOINT_AGENT_OCR_MAX_CHARS=1000000
# Set to off/false to disable the bundled WASM OCR fallback (default on). The
# fallback is fully offline and never fetches model weights from the network.
ENDPOINT_AGENT_OCR_WASM=on
# Strict mode (default off): when on, an image whose OCR yields little or no
# text is still routed to ocr_required/the approval queue instead of being
# allowed through on sparse extraction.
ENDPOINT_AGENT_OCR_STRICT=off

# Optional comma-separated list of sanctioned endpoint AI tools. If set,
# endpoint install-health marks detected local AI tools outside the list as
# attention using sanitized ids only, such as cursor or claude_desktop.
ENDPOINT_AGENT_APPROVED_AI_TOOLS=

# Comma-separated sanitized MCP server ids that are approved (shadow-MCP
# discovery). Empty = all discovered servers are treated as approved. Endpoint
# heartbeats report server id, client, and transport only — never env values,
# args, headers, URL paths, or query strings.
ENDPOINT_AGENT_APPROVED_MCP_SERVERS=
# Optional extra project roots to scan for .mcp.json / .cursor / .vscode configs.
ENDPOINT_AGENT_MCP_PROJECT_ROOTS=

# Optional named endpoint file-flow watchers for app/drop/staging folders.
# Heartbeats expose profile ids and status only, not local paths.
ENDPOINT_AGENT_FILE_FLOW_PROFILES=

# Per-app guarded drop folders for detected desktop AI apps (ChatGPT Desktop,
# Claude Desktop, Microsoft Copilot, Cursor, Windsurf). Set to 1 to provision
# and watch a guarded folder per installed app under <watch dir>/AI Apps, or
# set an explicit base directory. Checks expose tool ids only, never paths.
ENDPOINT_AGENT_APP_FLOW=
ENDPOINT_AGENT_APP_FLOW_DIR=

# Optional MCP connector runtime settings. Health checks expose only bounded
# presence/scope metadata, never tokens, DSNs, SQL, document IDs, or tool output.
ATLASSIAN_SITE_URL=
ATLASSIAN_ACCESS_TOKEN=
ATLASSIAN_API_TOKEN=
ATLASSIAN_EMAIL=
ATLASSIAN_SCOPES=
MCP_DATABASE_DSN=
MCP_DATABASE_LABEL=
MCP_DATABASE_SCOPES=

# Optional bearer token that enables /scim/v2 user and group provisioning.
# Leave empty to disable SCIM. Use a long random value when enabled.
SCIM_BEARER_TOKEN=

# Optional console SSO. Requires SCIM provisioning so signed IdP users map to
# active RedactWall users and roles. Use `npm run identity:setup -- --provider
# entra --base-url https://redactwall.customer.example --tenant-id <tenant>` or
# `--provider okta` to print provider-specific, secret-free setup values.
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
OIDC_SCOPE=openid email profile
# Leave these empty to use issuer discovery, or set all three together.
OIDC_AUTHORIZATION_ENDPOINT=
OIDC_TOKEN_ENDPOINT=
OIDC_JWKS_URI=

# Optional outbound request timeout for sensors and integration scripts.
REDACTWALL_REQUEST_TIMEOUT_MS=10000

# Optional sanitized SIEM/SOC webhook for high-risk events and posture feeds.
# Payloads contain masked findings and metadata only, never raw prompt text,
# freeform gap text, raw audit details, or token vaults.
SIEM_WEBHOOK_URL=
SIEM_WEBHOOK_TOKEN=
SIEM_ALERT_MIN_RISK=25
SIEM_ALERT_MIN_SEVERITY=3
SIEM_POSTURE_FEED_ENABLED=false
SIEM_POSTURE_MIN_INTERVAL_MS=300000

# Optional sanitized approval workflow notifications. Payloads contain query id,
# owner, SLA, labels, severity, and routing context only.
REDACTWALL_APPROVAL_NOTIFY_WEBHOOK_URL=
REDACTWALL_APPROVAL_NOTIFY_WEBHOOK_TOKEN=
REDACTWALL_APPROVAL_SLACK_WEBHOOK_URL=
REDACTWALL_APPROVAL_TEAMS_WEBHOOK_URL=
REDACTWALL_APPROVAL_TICKET_WEBHOOK_URL=
REDACTWALL_APPROVAL_TICKET_WEBHOOK_TOKEN=
REDACTWALL_APPROVAL_TICKET_SYSTEM=
REDACTWALL_APPROVAL_TICKET_PROJECT=
REDACTWALL_APPROVAL_TICKET_ISSUE_TYPE=
REDACTWALL_APPROVAL_JIRA_BASE_URL=
REDACTWALL_APPROVAL_JIRA_EMAIL=
REDACTWALL_APPROVAL_JIRA_API_TOKEN=
REDACTWALL_APPROVAL_JIRA_PROJECT_KEY=
REDACTWALL_APPROVAL_JIRA_ISSUE_TYPE=Task
# Native Linear smoke: npm run smoke:linear-approval -- -- --team-id=<linear-team-id> --send
REDACTWALL_APPROVAL_LINEAR_API_KEY=
REDACTWALL_APPROVAL_LINEAR_TEAM_ID=
REDACTWALL_APPROVAL_LINEAR_STATE_ID=
REDACTWALL_APPROVAL_LINEAR_PROJECT_ID=
REDACTWALL_APPROVAL_LINEAR_LABEL_IDS=
REDACTWALL_APPROVAL_SMTP_HOST=
REDACTWALL_APPROVAL_SMTP_PORT=
REDACTWALL_APPROVAL_SMTP_FROM=
REDACTWALL_APPROVAL_SMTP_TO=
REDACTWALL_APPROVAL_SMTP_USERNAME=
REDACTWALL_APPROVAL_SMTP_PASSWORD=
REDACTWALL_APPROVAL_SMTP_SECURE=false
REDACTWALL_APPROVAL_SMTP_ALLOW_INSECURE=false
