# PromptWall configuration — copy to .env and adjust (or export in your shell)

# The legacy SENTINEL_* keys below remain supported for existing installs.
# New deployments may use the equivalent PROMPTWALL_* aliases documented in
# README.md and docs/DEPLOYMENT.md.

# Web/admin server
PORT=4000
NODE_ENV=development

# Set HTTPS=true or COOKIE_SECURE=true when the dashboard is served over TLS.
HTTPS=false
COOKIE_SECURE=false

# SQLite store path. Keep this on local disk, not a cloud-synced folder.
SENTINEL_DB_PATH=./data/sentinel.db

# Optional policy and customer detector-pack paths. Docker customer-silo
# deployments default these to /data so policy edits survive image replacement.
SENTINEL_POLICY_PATH=
SENTINEL_CUSTOM_DETECTORS_PATH=

# Security Admin console credentials (CHANGE THESE before any real use)
ADMIN_USER=admin
ADMIN_PASSWORD=ChangeMe!2026
# Optional in development, required by production preflight for Security Admin login.
# Use a base32 secret from an authenticator app enrollment flow.
ADMIN_TOTP_SECRET=

# Optional read-only console account for demos and examiner reviews.
# Set both values together, and keep AUDITOR_USER distinct from ADMIN_USER.
AUDITOR_USER=
AUDITOR_PASSWORD=

# Secret used to sign session cookies (set a long random value in production)
SENTINEL_SECRET=

# Key for encrypting retained raw prompts at rest (AES-256-GCM). Set a long
# random value and keep it STABLE across restarts, or sealed data can't be read.
# If unset, SENTINEL_SECRET is used; if neither is set, raw prompts are not stored.
SENTINEL_DATA_KEY=

# API key the network proxy / SDK presents to the /api/v1/gate endpoint.
# Use a long random value for pilots and production.
INGEST_API_KEY=dev-ingest-key

# Optional app-to-LLM gateway settings for private apps and internal agents.
# Use a long client token and keep provider keys on the gateway host only.
PROMPTWALL_GATEWAY_TOKEN=
PROMPTWALL_GATEWAY_HOST=127.0.0.1
PROMPTWALL_GATEWAY_UPSTREAM=https://api.openai.com
PROMPTWALL_GATEWAY_UPSTREAM_API_KEY=
PROMPTWALL_GATEWAY_UPSTREAM_AUTH_HEADER=authorization
PROMPTWALL_GATEWAY_UPSTREAM_AUTH_SCHEME=Bearer
PROMPTWALL_GATEWAY_AWS_REGION=
PROMPTWALL_GATEWAY_AWS_SERVICE=bedrock
PROMPTWALL_GATEWAY_AWS_ACCESS_KEY_ID=
PROMPTWALL_GATEWAY_AWS_SECRET_ACCESS_KEY=
PROMPTWALL_GATEWAY_AWS_SESSION_TOKEN=
PROMPTWALL_GATEWAY_RATE_LIMIT=60
PROMPTWALL_GATEWAY_RATE_WINDOW_MS=60000
# Use sqlite to share counters across same-host gateway workers, or http to
# delegate hashed limiter keys to a shared Redis/KV-backed limiter service.
PROMPTWALL_GATEWAY_RATE_LIMIT_STORE=memory
PROMPTWALL_GATEWAY_RATE_LIMIT_DB=./data/gateway-rate-limits.db
PROMPTWALL_GATEWAY_RATE_LIMIT_URL=
PROMPTWALL_GATEWAY_RATE_LIMIT_TOKEN=
PROMPTWALL_GATEWAY_RATE_LIMIT_TIMEOUT_MS=2000
PROMPTWALL_GATEWAY_ALLOWED_MODELS=

# Optional central limiter service for multi-worker or multi-host AI gateway
# deployments. Gateways call this with hashed client-token keys only.
PROMPTWALL_RATE_LIMITER_TOKEN=
PROMPTWALL_RATE_LIMITER_STORE=sqlite
PROMPTWALL_RATE_LIMITER_DB=./data/gateway-shared-rate-limiter.db
PROMPTWALL_RATE_LIMITER_REDIS_URL=
PROMPTWALL_RATE_LIMITER_REDIS_PREFIX=promptwall:gateway:rl:
PROMPTWALL_RATE_LIMITER_REDIS_TIMEOUT_MS=2000

# Optional endpoint-local OCR for image files. When unset, the agent
# auto-discovers a local tesseract install; without one, images stay
# ocr_required. Point at a specific local command to override; args JSON can
# include "{file}".
ENDPOINT_AGENT_OCR_COMMAND=
ENDPOINT_AGENT_OCR_ARGS_JSON=
ENDPOINT_AGENT_OCR_TIMEOUT_MS=15000
ENDPOINT_AGENT_OCR_MAX_CHARS=1000000

# Optional comma-separated list of sanctioned endpoint AI tools. If set,
# endpoint install-health marks detected local AI tools outside the list as
# attention using sanitized ids only, such as cursor or claude_desktop.
ENDPOINT_AGENT_APPROVED_AI_TOOLS=

# Optional named endpoint file-flow watchers for app/drop/staging folders.
# Heartbeats expose profile ids and status only, not local paths.
ENDPOINT_AGENT_FILE_FLOW_PROFILES=

# Per-app guarded drop folders for detected desktop AI apps (ChatGPT Desktop,
# Claude Desktop, Microsoft Copilot, Cursor, Windsurf). Set to 1 to provision
# and watch a guarded folder per installed app under <watch dir>/AI Apps, or
# set an explicit base directory. Checks expose tool ids only, never paths.
ENDPOINT_AGENT_APP_FLOW=
ENDPOINT_AGENT_APP_FLOW_DIR=

# Optional MCP connector runtime settings. Health checks expose only bounded
# presence/scope metadata, never tokens, DSNs, SQL, document IDs, or tool output.
ATLASSIAN_SITE_URL=
ATLASSIAN_ACCESS_TOKEN=
ATLASSIAN_API_TOKEN=
ATLASSIAN_EMAIL=
ATLASSIAN_SCOPES=
MCP_DATABASE_DSN=
MCP_DATABASE_LABEL=
MCP_DATABASE_SCOPES=

# Optional bearer token that enables /scim/v2 user and group provisioning.
# Leave empty to disable SCIM. Use a long random value when enabled.
SCIM_BEARER_TOKEN=

# Optional console SSO. Requires SCIM provisioning so signed IdP users map to
# active PromptWall users and roles. Use `npm run identity:setup -- --provider
# entra --base-url https://promptwall.customer.example --tenant-id <tenant>` or
# `--provider okta` to print provider-specific, secret-free setup values.
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
OIDC_SCOPE=openid email profile
# Leave these empty to use issuer discovery, or set all three together.
OIDC_AUTHORIZATION_ENDPOINT=
OIDC_TOKEN_ENDPOINT=
OIDC_JWKS_URI=

# Optional outbound request timeout for sensors and integration scripts.
SENTINEL_REQUEST_TIMEOUT_MS=10000

# Optional sanitized SIEM/SOC webhook for high-risk events and posture feeds.
# Payloads contain masked findings and metadata only, never raw prompt text,
# freeform gap text, raw audit details, or token vaults.
SIEM_WEBHOOK_URL=
SIEM_WEBHOOK_TOKEN=
SIEM_ALERT_MIN_RISK=25
SIEM_ALERT_MIN_SEVERITY=3
SIEM_POSTURE_FEED_ENABLED=false
SIEM_POSTURE_MIN_INTERVAL_MS=300000

# Optional sanitized approval workflow notifications. Payloads contain query id,
# owner, SLA, labels, severity, and routing context only.
PROMPTWALL_APPROVAL_NOTIFY_WEBHOOK_URL=
PROMPTWALL_APPROVAL_NOTIFY_WEBHOOK_TOKEN=
PROMPTWALL_APPROVAL_SLACK_WEBHOOK_URL=
PROMPTWALL_APPROVAL_TEAMS_WEBHOOK_URL=
PROMPTWALL_APPROVAL_TICKET_WEBHOOK_URL=
PROMPTWALL_APPROVAL_TICKET_WEBHOOK_TOKEN=
PROMPTWALL_APPROVAL_TICKET_SYSTEM=
PROMPTWALL_APPROVAL_TICKET_PROJECT=
PROMPTWALL_APPROVAL_TICKET_ISSUE_TYPE=
PROMPTWALL_APPROVAL_JIRA_BASE_URL=
PROMPTWALL_APPROVAL_JIRA_EMAIL=
PROMPTWALL_APPROVAL_JIRA_API_TOKEN=
PROMPTWALL_APPROVAL_JIRA_PROJECT_KEY=
PROMPTWALL_APPROVAL_JIRA_ISSUE_TYPE=Task
# Native Linear smoke: npm run smoke:linear-approval -- -- --team-id=<linear-team-id> --send
PROMPTWALL_APPROVAL_LINEAR_API_KEY=
PROMPTWALL_APPROVAL_LINEAR_TEAM_ID=
PROMPTWALL_APPROVAL_LINEAR_STATE_ID=
PROMPTWALL_APPROVAL_LINEAR_PROJECT_ID=
PROMPTWALL_APPROVAL_LINEAR_LABEL_IDS=
PROMPTWALL_APPROVAL_SMTP_HOST=
PROMPTWALL_APPROVAL_SMTP_PORT=
PROMPTWALL_APPROVAL_SMTP_FROM=
PROMPTWALL_APPROVAL_SMTP_TO=
PROMPTWALL_APPROVAL_SMTP_USERNAME=
PROMPTWALL_APPROVAL_SMTP_PASSWORD=
PROMPTWALL_APPROVAL_SMTP_SECURE=false
PROMPTWALL_APPROVAL_SMTP_ALLOW_INSECURE=false
