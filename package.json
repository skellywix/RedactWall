{
  "name": "promptwall",
  "version": "0.3.0",
  "description": "Inline DLP gateway for AI chat prompts - detects PII, blocks risky prompts, reversibly redacts, and releases only after Security Admin approval. Built for compliance (NCUA/GLBA/PCI/HIPAA) at credit unions and similar.",
  "main": "server/app.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "hooks:install": "git config core.hooksPath .githooks",
    "review:ci": "git diff --check && npm run docs:demo-guide:check && npm run ai-domains:check && npm run native:check && npm test && npm run test:browser && npm run sync-check && npm run eval",
    "review:agent": "npm run review:ci",
    "setup": "node scripts/setup.js",
    "setup:prod": "node scripts/setup.js --production",
    "setup:check": "node scripts/setup.js --check --skip-install",
    "mfa:uri": "node scripts/mfa-uri.js",
    "start": "node server/app.js",
    "gateway": "node gateway/server.js",
    "gateway:token": "node gateway/mint-token.js",
    "test": "node scripts/run-node-tests.js",
    "native:check": "node scripts/ensure-native-bindings.js",
    "native:check:repair": "node scripts/ensure-native-bindings.js --repair",
    "test:browser": "node scripts/run-playwright.js",
    "test:admin-console": "node scripts/run-playwright.js admin-console.spec.js",
    "test:browser-extension": "node scripts/run-playwright.js browser-extension.spec.js --project=chromium",
    "simulate": "node scripts/simulate.js",
    "fire-drill": "node scripts/fire-drill.js",
    "smoke:linear-approval": "node scripts/smoke-linear-approval.js",
    "backup": "node scripts/backup-store.js create",
    "backup:verify": "node scripts/backup-store.js verify",
    "backup:restore": "node scripts/backup-store.js restore",
    "evidence:pack": "node scripts/export-evidence-pack.js",
    "evidence:pack:zip": "node scripts/export-evidence-pack.js --zip",
    "evidence:pack:scheduled": "node scripts/export-evidence-pack.js --schedule",
    "evidence:pack:install-task": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/install-evidence-pack-task.ps1",
    "evidence:pack:run-linux": "bash scripts/run-evidence-pack.sh",
    "evidence:pack:install-systemd": "bash scripts/install-evidence-pack-systemd.sh",
    "package:extension": "node scripts/package-extension.js",
    "release:extension:check": "node scripts/check-extension-release.js",
    "package:endpoint-agent": "node scripts/package-endpoint-agent.js",
    "package:mcp-guard": "node scripts/package-mcp-guard.js",
    "docs:sync": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/sync-docs.ps1",
    "docs:sync:check": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/sync-docs.ps1 -CheckOnly",
    "docs:sync:install-task": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/install-docs-sync-task.ps1",
    "docs:demo-guide": "node scripts/update-demo-guide.js",
    "docs:demo-guide:check": "node scripts/update-demo-guide.js --check",
    "endpoint:check": "node scripts/check-endpoint-install.js",
    "endpoint:handoff": "node sensors/endpoint-agent/write-handoff.js",
    "desktop:collect": "node sensors/endpoint-agent/collectors/protected-upload.js",
    "desktop:clipboard": "node sensors/endpoint-agent/collectors/clipboard-guard.js",
    "mcp:check": "node scripts/check-mcp-guard-install.js",
    "identity:setup": "node scripts/identity-setup.js",
    "train-semantic": "node scripts/train-semantic.js",
    "edm:fingerprint": "node scripts/edm-fingerprint.js",
    "sync-engine": "node scripts/sync-engine.js",
    "sync-check": "node scripts/sync-check.js",
    "ai-domains:check": "node scripts/check-ai-domain-coverage.js",
    "eval": "node scripts/eval-detect.js",
    "docker:mecha": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/mecha-docker.ps1 start",
    "docker:mecha:rebuild": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/mecha-docker.ps1 rebuild",
    "docker:mecha:restart": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/mecha-docker.ps1 restart",
    "docker:mecha:stop": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/mecha-docker.ps1 stop",
    "docker:mecha:status": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/mecha-docker.ps1 status",
    "docker:mecha:check": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/mecha-docker.ps1 check",
    "docker:mecha:smoke": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/mecha-docker.ps1 smoke",
    "docker:mecha:logs": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/mecha-docker.ps1 logs"
  },
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^12.11.1",
    "cookie-parser": "^1.4.6",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "pdf-parse": "^2.4.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
