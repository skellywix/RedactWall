{
  "manifest_version": 3,
  "name": "RedactWall - AI Data Guard",
  "version": "0.4.0",
  "description": "Warns, redacts, or blocks sensitive data (PII, source code, credentials, confidential info) before it is sent to ChatGPT, Claude, Copilot, Gemini, and other AI tools.",
  "permissions": ["storage", "activeTab", "tabs", "alarms", "downloads", "nativeMessaging", "clipboardWrite", "scripting", "declarativeNetRequest"],
  "host_permissions": [
    "http://localhost:4000/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "optional_host_permissions": ["https://*/*"],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "coverage_base",
        "enabled": true,
        "path": "rules/coverage-base.json"
      }
    ]
  },
  "background": { "service_worker": "background.js" },
  "storage": { "managed_schema": "schema.json" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "RedactWall"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://bard.google.com/*",
        "https://gemini.google.com/*",
        "https://aistudio.google.com/*",
        "https://notebooklm.google.com/*",
        "https://copilot.microsoft.com/*",
        "https://bing.com/*",
        "https://www.bing.com/*",
        "https://perplexity.ai/*",
        "https://www.perplexity.ai/*",
        "https://poe.com/*",
        "https://www.poe.com/*",
        "https://character.ai/*",
        "https://*.character.ai/*",
        "https://huggingface.co/*",
        "https://*.huggingface.co/*",
        "https://you.com/*",
        "https://*.you.com/*",
        "https://pi.ai/*",
        "https://*.pi.ai/*",
        "https://deepseek.com/*",
        "https://*.deepseek.com/*",
        "https://qwen.ai/*",
        "https://*.qwen.ai/*",
        "https://tongyi.aliyun.com/*",
        "https://qianwen.aliyun.com/*",
        "https://kimi.com/*",
