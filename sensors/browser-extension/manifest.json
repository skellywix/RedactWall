{
  "manifest_version": 3,
  "name": "PromptWall — AI Data Guard",
  "version": "0.3.0",
  "description": "Warns, redacts, or blocks sensitive data (PII, source code, credentials, confidential info) before it is sent to ChatGPT, Claude, Copilot, Gemini, and other AI tools.",
  "permissions": ["storage", "activeTab", "tabs", "alarms"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://copilot.microsoft.com/*",
    "https://www.perplexity.ai/*",
    "https://poe.com/*",
    "https://www.poe.com/*",
    "http://localhost:4000/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": { "service_worker": "background.js" },
  "storage": { "managed_schema": "schema.json" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "PromptWall"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://copilot.microsoft.com/*",
        "https://www.perplexity.ai/*",
        "https://poe.com/*",
        "https://www.poe.com/*"
      ],
      "js": ["lib/detect.js", "lib/adapters.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
